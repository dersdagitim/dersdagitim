<Window x:Class="DersDagitim.Views.CurriculumImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ders Havuzu Şablonları" Width="650" Height="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Ders Havuzu Şablonları" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Okul türünüze uygun ders şablonunu indirip ders havuzunuza aktarabilirsiniz. Mevcut derslerle çakışan kayıtlar atlanır."
                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Template List -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}">
            <Grid>
                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Şablonlar yükleniyor..." FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Error -->
                <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Text="Şablonlar yüklenemedi." FontSize="14" Foreground="{DynamicResource ErrorBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Button Content="Tekrar Dene" Click="Retry_Click" Margin="0,10,0,0"
                            HorizontalAlignment="Center" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>

                <!-- Template Items -->
                <ListBox x:Name="TemplateListBox" Visibility="Collapsed" Background="Transparent"
                         BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="TemplateListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0" Text="📚" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <!-- Name & Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding InfoText}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <!-- Status -->
                                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="10,0"/>

                                <!-- Progress -->
                                <ProgressBar Grid.Column="3" Width="100" Height="8" Minimum="0" Maximum="100"
                                             Value="{Binding DownloadPercent}" VerticalAlignment="Center"
                                             Visibility="{Binding ProgressVisibility}"
                                             Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="2" x:Name="FooterText" Text="" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
    </Grid>
</Window>
